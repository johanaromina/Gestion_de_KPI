# Runtime
NODE_ENV=production
PORT=5000

# Public URLs
APP_BASE_URL=https://demo.kpimanager.com.ar
FRONTEND_BASE_URL=https://demo.kpimanager.com.ar
PUBLIC_API_BASE_URL=https://demo.kpimanager.com.ar/api
SELF_REGISTER_ENABLED=false

# Database
DB_HOST=mysql
DB_PORT=3306
DB_USER=gestion_kpi
DB_PASSWORD=CAMBIAR_PASSWORD_FUERTE
DB_NAME=gestion_kpi

# Security
JWT_SECRET=CAMBIAR_POR_CLAVE_LARGA_Y_UNICA
AUTH_ENCRYPTION_KEY=CAMBIAR_POR_CLAVE_LARGA_DISTINTA
JWT_EXPIRES_IN=7d
MFA_TTL_MIN=10
RESET_TTL_MIN=60
SSO_STATE_TTL_MIN=10
SSO_HANDOFF_TTL_MIN=5
CORS_ALLOWED_ORIGINS=https://demo.kpimanager.com.ar
TRUST_PROXY=true

# SMTP
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=usuario
SMTP_PASS=CAMBIAR_PASSWORD
SMTP_FROM="KPI Manager <no-reply@kpimanager.com.ar>"
SMTP_REPLY_TO=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_IPV4_ONLY=true

# Integrations
INTEGRATIONS_RUN_DELAY_MS=2000
INTEGRATIONS_RETRY_MS=60000
INTEGRATIONS_CACHE_HOURS=12

# Optional
LOG_LEVEL=info
