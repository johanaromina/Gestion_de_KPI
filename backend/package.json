{
  "name": "gestion-kpi-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "setup:db": "tsx scripts/setup-database.ts",
    "test:db": "tsx scripts/test-connection.ts",
    "add:audit": "tsx scripts/add-audit-table.ts",
    "verify:audit": "tsx scripts/verify-audit-table.ts",
    "add:collaborator-kpi-plan": "tsx scripts/add-collaborator-kpi-plan-table.ts",
    "import:plan": "tsx scripts/import-kpi-plan.ts",
    "add:objective-kpis": "tsx scripts/add-objective-trees-kpis-table.ts",
    "import:excel": "tsx scripts/import-objectives-from-excel.ts",
    "seed:objectives": "tsx scripts/seed-objectives-tree.ts",
    "seed:areas": "tsx scripts/seed-objectives-areas.ts",
    "add:evolution": "tsx scripts/add-evolution-table.ts",
    "import:evolution": "tsx scripts/import-evolution-from-excel.ts",
    "add:auth-columns": "tsx scripts/add-auth-columns.ts",
    "bootstrap:admin": "tsx scripts/bootstrap-client-admin.ts",
    "add:notifications-table": "tsx scripts/add-notifications-table.ts",
    "add:subperiod-status": "tsx scripts/add-subperiod-status.ts",
    "test:critical-flow": "tsx scripts/smoke-critical-flow.ts",
    "test:sheets": "node --import tsx --test tests/integrations/sheets.test.ts",
    "test:smtp": "tsx scripts/test-smtp.ts",
    "test:okr": "node --import tsx --test tests/okr.test.ts",
    "test:auth": "node --import tsx --test tests/auth.test.ts",
    "test:unit": "node --import tsx --test tests/okr.test.ts tests/auth.test.ts",
    "smoke:prod": "tsx scripts/smoke-prod.ts"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.12",
    "pdfkit": "^0.17.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2"
  }
}
