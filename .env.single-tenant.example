# Nombre interno del cliente
CLIENT_SLUG=cliente-demo

# Puertos publicados en el host
# Si 33060 ya esta ocupado en local, cambia MYSQL_PORT a 33061 o similar.
FRONTEND_PORT=8080
BACKEND_PORT=5000
MYSQL_PORT=33060

# URLs publicas
# Para una primera validacion sin dominio puedes usar http://localhost:8080
APP_BASE_URL=https://demo.kpimanager.com.ar
FRONTEND_BASE_URL=https://demo.kpimanager.com.ar
PUBLIC_API_BASE_URL=https://demo.kpimanager.com.ar/api
CORS_ALLOWED_ORIGINS=https://demo.kpimanager.com.ar
TRUST_PROXY=true
SELF_REGISTER_ENABLED=false
VITE_SELF_REGISTER_ENABLED=false
VITE_CONTACT_EMAIL=
VITE_CONTACT_PHONES=+54 9 2604618942,+54 9 1151104758
VITE_CONTACT_DEMO_SUBJECT=Solicitud de demo KPI Manager

# Base MySQL del cliente
MYSQL_ROOT_PASSWORD=CAMBIAR_ROOT_PASSWORD
MYSQL_DATABASE=gestion_kpi
MYSQL_USER=gestion_kpi
MYSQL_PASSWORD=CAMBIAR_PASSWORD_APP

# Auth de la app
JWT_SECRET=CAMBIAR_POR_CLAVE_LARGA_Y_UNICA
AUTH_ENCRYPTION_KEY=CAMBIAR_POR_CLAVE_LARGA_DISTINTA
JWT_EXPIRES_IN=7d
MFA_TTL_MIN=10
RESET_TTL_MIN=60
SSO_STATE_TTL_MIN=10
SSO_HANDOFF_TTL_MIN=5

# Correo
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=usuario
SMTP_PASS=CAMBIAR_PASSWORD
SMTP_FROM="KPI Manager <no-reply@kpimanager.com.ar>"
SMTP_REPLY_TO=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_IPV4_ONLY=true

# Integraciones
INTEGRATIONS_RUN_DELAY_MS=2000
INTEGRATIONS_RETRY_MS=60000
INTEGRATIONS_CACHE_HOURS=12

# Logs
LOG_LEVEL=info
